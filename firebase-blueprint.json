{
  "entities": {
    "User": {
      "title": "User",
      "description": "Profile information for Q-Bank Pro users",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The firebase authenticated user UID" },
        "email": { "type": "string", "description": "The user's educational email address" },
        "role": { "type": "string", "description": "System role, e.g. user or admin" },
        "createdAt": { "type": "string", "format": "date-time", "description": "ISO timestamp representing profile creation" }
      },
      "required": ["id", "email", "createdAt"]
    },
    "Question": {
      "title": "Question",
      "description": "An academic multiple choice question",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique stable identifier of the question" },
        "question_text": { "type": "string", "description": "Body of the academic question in elegant Arabic" },
        "options": { "type": "array", "description": "Exactly four alternative multiple choices for the students" },
        "correct_answer": { "type": "string", "description": "Correct answer letter (Arabic letters: أ، ب، ج، د)" },
        "subject": { "type": "string", "description": "Subject category (e.g. الرياضيات, الفيزياء)" },
        "difficulty": { "type": "string", "enum": ["سهل", "متوسط", "صعب"], "description": "Difficulty descriptor" },
        "created_at": { "type": "string", "format": "date-time", "description": "ISO timestamp of creation" },
        "userId": { "type": "string", "description": "Auth UID of the teacher/user who added this question" }
      },
      "required": ["id", "question_text", "options", "correct_answer", "subject", "difficulty", "userId"]
    },
    "Exam": {
      "title": "Exam",
      "description": "A generated test consisting of multiple choice questions",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique test identifier" },
        "title": { "type": "string", "description": "Display title of the test papers" },
        "subject": { "type": "string", "description": "Selected subject category" },
        "difficulty": { "type": "string", "description": "Difficulty parameters" },
        "duration": { "type": "string", "description": "Assigned time for answering" },
        "questions": { "type": "array", "description": "Subset array of questions embedded in the exam" },
        "created_at": { "type": "string", "format": "date-time", "description": "ISO timestamp" },
        "userId": { "type": "string", "description": "Auth UID of the generator of this exam" }
      },
      "required": ["id", "title", "subject", "difficulty", "duration", "questions", "created_at", "userId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Isolated profiles of registered users"
    },
    "questions/{questionId}": {
      "schema": "Question",
      "description": "Unified database of interactive questions"
    },
    "exams/{examId}": {
      "schema": "Exam",
      "description": "Stored sets of exams generated by teachers"
    }
  }
}
